#!/bin/bash

# Get the current branch name
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"

if [ "$branch" = "main" ]; then
  echo "==========================================================="
  echo "⚠️  WARNING: You are trying to commit directly to 'main'!"
  echo "==========================================================="
  echo "Best practices suggest creating a new branch from develop and opening a PR."
  echo "If you cant do this contact repo owner..."
  exit 1
fi

exit 0
