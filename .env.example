# Database
# For running locally without docker:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/lms_platform"
# For running with docker-compose:
DATABASE_URL="postgresql://postgres:password@db:5432/lms_platform"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Object Storage (S3-compatible)
STORAGE_ENDPOINT="https://s3.amazonaws.com"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="lms-platform-assets"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_PUBLIC_URL=""
